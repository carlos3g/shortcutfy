{
  "name": "shortcutfy",
  "version": "1.0.0",
  "description": "Configurable keyboard shortcuts for navigating Chromium browsers without the mouse.",
  "type": "module",
  "scripts": {
    "format": "prettier --write \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "lint": "eslint \"{src,scripts}/**/*.ts\" --fix",
    "style": "yarn format && yarn lint",
    "clean": "rm -rf dist tsconfig.tsbuildinfo tsconfig.build.tsbuildinfo shortcutfy-*.zip",
    "build": "tsx scripts/build.ts",
    "build:icons": "tsx scripts/build-icons.ts",
    "build:commands": "tsx src/build-manifest-commands.ts",
    "package": "tsx scripts/package.ts",
    "release": "tsx scripts/release.ts",
    "start:dev": "yarn build && tsc --project tsconfig.build.json --watch",
    "test": "tsc --noEmit",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "carlos3g",
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@types/chrome": "^0.1.40",
    "@types/node": "^22.10.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0"
  }
}
